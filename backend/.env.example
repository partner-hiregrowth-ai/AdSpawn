PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/ads_duplicator?schema=public"
JWT_SECRET="your_jwt_secret_here"
FB_APP_ID="your_facebook_app_id"
FB_APP_SECRET="your_facebook_app_secret"

# Comma-separated list of allowed CORS origins (defaults to localhost:3000 + production Vercel URL)
# ALLOWED_ORIGIN="https://your-frontend.example.com"

# AI Create feature (optional — endpoints error gracefully if unset)
# AI_PROVIDER=claude            # claude | openai | gemini | groq
# AI_MODEL=                     # override default model for the provider
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# Live Meta API drift tests only (npm run test:drift)
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=
