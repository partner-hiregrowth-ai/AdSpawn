generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  facebookId      String            @unique
  email           String?
  name            String?
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  createdAt             DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  duplicateJobs   DuplicateJob[]
  accounts        FacebookAccount[]
  namingTemplates NamingTemplate[]
  draftCampaigns  DraftCampaign[]
  draftAdSets     DraftAdSet[]
  draftAds        DraftAd[]
}

model FacebookAccount {
  id           String   @id @default(cuid())
  adAccountId  String   @unique
  name         String
  currency     String?
  timezoneName String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model DuplicateJob {
  id        String   @id @default(cuid())
  userId    String
  status    String
  type      String
  sourceId  String
  targetId  String?
  details   Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model NamingTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  pattern   String
  type      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

enum DraftStatus {
  DRAFT
  READY
  VALIDATION_FAILED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

model DraftCampaign {
  id              String        @id @default(cuid())
  userId          String
  adAccountId     String
  name            String
  objective       String?
  status          DraftStatus   @default(DRAFT)
  metaId          String?       // Populated after publish
  data            Json          // Full campaign settings
  validationErrors Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  adSets          DraftAdSet[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
}

model DraftAdSet {
  id              String        @id @default(cuid())
  draftCampaignId String
  userId          String
  adAccountId     String
  name            String
  status          DraftStatus   @default(DRAFT)
  metaId          String?       // Populated after publish
  data            Json          // Full ad set settings
  validationErrors Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  campaign        DraftCampaign @relation(fields: [draftCampaignId], references: [id], onDelete: Cascade)
  ads             DraftAd[]

  @@index([userId])
  @@index([userId, status])
  @@index([draftCampaignId])
}

model DraftAd {
  id              String        @id @default(cuid())
  draftAdSetId    String
  userId          String
  adAccountId     String
  name            String
  status          DraftStatus   @default(DRAFT)
  metaId          String?       // Populated after publish
  data            Json          // Full ad settings
  validationErrors Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  adSet           DraftAdSet    @relation(fields: [draftAdSetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([draftAdSetId])
}

model DraftPublishLog {
  id        String   @id @default(cuid())
  draftId   String
  draftType String   // CAMPAIGN, ADSET, AD
  status    String
  message   String?
  payload   Json?
  response  Json?
  error     String?
  createdAt DateTime @default(now())
}
