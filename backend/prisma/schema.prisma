generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id         String    @id @default(cuid())
  name       String
  inviteCode String    @unique
  ownerId    String    @unique
  owner      User      @relation("TeamOwner", fields: [ownerId], references: [id])
  members    User[]    @relation("TeamMembers")
  profiles   Profile[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Profile {
  id             String          @id @default(cuid())
  name           String
  teamId         String
  team           Team            @relation(fields: [teamId], references: [id])
  draftCampaigns DraftCampaign[]
  draftAdSets    DraftAdSet[]
  draftAds       DraftAd[]
  duplicateJobs  DuplicateJob[]
  createdAt      DateTime        @default(now())

  @@index([teamId])
}

model User {
  id                    String            @id @default(cuid())
  facebookId            String?           @unique
  email                 String?           @unique
  name                  String?
  passwordHash          String?
  role                  String            @default("member")
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  teamId                String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  team                  Team?             @relation("TeamMembers", fields: [teamId], references: [id])
  ownedTeam             Team?             @relation("TeamOwner")
  duplicateJobs         DuplicateJob[]
  accounts              FacebookAccount[]
  namingTemplates       NamingTemplate[]
}

model FacebookAccount {
  id           String   @id @default(cuid())
  adAccountId  String   @unique
  name         String
  currency     String?
  timezoneName String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model DuplicateJob {
  id        String   @id @default(cuid())
  userId    String
  profileId String?
  status    String
  type      String
  sourceId  String
  targetId  String?
  details   Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
}

model NamingTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  pattern   String
  type      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

enum DraftStatus {
  DRAFT
  VALIDATED
  VALIDATION_FAILED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

model DraftCampaign {
  id              String        @id @default(cuid())
  profileId       String
  adAccountId     String
  name            String
  objective       String?
  status          DraftStatus   @default(DRAFT)
  metaId          String?
  data            Json
  validationErrors Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         Profile       @relation(fields: [profileId], references: [id])
  adSets          DraftAdSet[]

  @@index([profileId, status])
  @@index([profileId, createdAt(sort: Desc)])
}

model DraftAdSet {
  id              String        @id @default(cuid())
  draftCampaignId String
  profileId       String
  adAccountId     String
  name            String
  status          DraftStatus   @default(DRAFT)
  metaId          String?
  data            Json
  validationErrors Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         Profile       @relation(fields: [profileId], references: [id])
  campaign        DraftCampaign @relation(fields: [draftCampaignId], references: [id], onDelete: Cascade)
  ads             DraftAd[]

  @@index([profileId])
  @@index([profileId, status])
  @@index([draftCampaignId])
}

model DraftAd {
  id              String        @id @default(cuid())
  draftAdSetId    String
  profileId       String
  adAccountId     String
  name            String
  status          DraftStatus   @default(DRAFT)
  metaId          String?
  data            Json
  validationErrors Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         Profile       @relation(fields: [profileId], references: [id])
  adSet           DraftAdSet    @relation(fields: [draftAdSetId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, status])
  @@index([draftAdSetId])
}

model DraftPublishLog {
  id        String   @id @default(cuid())
  draftId   String
  draftType String
  status    String
  message   String?
  payload   Json?
  response  Json?
  error     String?
  createdAt DateTime @default(now())
}
